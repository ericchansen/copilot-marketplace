{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}" },
      "tools": ["*"]
    },
    "msft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp",
      "tools": ["*"]
    },
    "playwright": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--browser", "msedge"],
      "tools": ["*"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "tools": ["*"]
    },
    "zotero": {
      "type": "local",
      "command": "uvx",
      "args": ["--from", "zotero-mcp-server", "zotero-mcp", "serve"],
      "env": {
        "ZOTERO_LOCAL": "false",
        "ZOTERO_LIBRARY_TYPE": "user",
        "ZOTERO_LIBRARY_ID": "1276304",
        "ZOTERO_API_KEY": "${ZOTERO_API_KEY}"
      },
      "tools": ["*"]
    }
  }
}
