{
  // ── Personal preferences ──────────────────────────────────────────────
  "banner": "always",
  "renderMarkdown": true,
  "experimental": true,
  "effortLevel": "high",
  // NOTE: "model" intentionally omitted — no pinned model default.
  // ── Marketplaces (where plugins are installed from) ───────────────────
  // Machine-injected directory marketplaces (e.g. Windows Terminal's
  // "wt-local") are intentionally NOT committed; link.ps1 preserves them
  // locally when deploying so this source stays clean.
  "extraKnownMarketplaces": {
    "copilot-marketplace": {
      "source": { "source": "github", "repo": "ericchansen/copilot-marketplace" }
    }
  },
  // ── Declarative auto-install (home profile: personal plugins only) ────
  "enabledPlugins": {
    "api-reverse-engineer@copilot-marketplace": true,
    "git-safety-scan@copilot-marketplace": true,
    "git-code-review@copilot-marketplace": true,
    "git-commit@copilot-marketplace": true,
    "github-writer@copilot-marketplace": true,
    "clean@copilot-marketplace": true,
    "pr-review-address@copilot-marketplace": true,
    "doc-generator@copilot-marketplace": true,
    "edge-browser@copilot-marketplace": true,
    "azure-doctor@copilot-marketplace": true
  }
}
