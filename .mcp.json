{
  "mcpServers": {

    "context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "msft-learn": {
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "WebIQ-MCP": {
      "url": "https://api.microsoft.ai/v3/mcp",
      "type": "http",
      "authtype": "api-key",
      "headers": {
        "x-apikey": "<your-api-key>"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--browser", "msedge"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
