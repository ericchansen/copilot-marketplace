{
  "servers": [
    {
      "name": "azure-mcp",
      "type": "npx",
      "package": "@azure/mcp@latest",
      "args": ["server", "start"],
      "tools": ["*"]
    },
    {
      "name": "context7",
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "tools": ["query-docs", "resolve-library-id"]
    },
    {
      "name": "microsoft-learn",
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp",
      "tools": ["*"]
    },
    {
      "name": "playwright",
      "type": "npx",
      "package": "@playwright/mcp@latest",
      "args": ["--browser", "msedge"],
      "tools": ["*"]
    },
    {
      "name": "chrome-devtools",
      "type": "npx",
      "package": "chrome-devtools-mcp@latest",
      "tools": ["*"]
    },
    {
      "name": "aifmt",
      "type": "local",
      "command": "aifmt",
      "repo": "https://github.com/ericchansen/aifmt.git",
      "cloneDir": "aifmt",
      "defaultPaths": ["~/repos/aifmt"],
      "build": ["python -m pip install -e ."],
      "tools": ["*"],
      "pluginFallback": "ericchansen/aifmt"
    }
  ]
}
